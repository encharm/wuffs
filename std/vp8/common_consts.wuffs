// TOKEN_EXTRA_BITS maps token categories to the number of extra bits to read.
// Tokens 0-4 have no extra bits. Token 5 (cat1) has 1, token 6 (cat2) has 2,
// etc.
pri const TOKEN_EXTRA_BITS : roarray[12] base.u8[..= 11] = [
        0, 0, 0, 0, 0, 1, 2, 3, 4, 5, 6, 11,
]

// TOKEN_EXTRA_BASE maps token categories to the base value.
// dct_val = base + extra_bits_value.
pri const TOKEN_EXTRA_BASE : roarray[12] base.u16 = [
        0, 1, 2, 3, 4, 5, 7, 11, 19, 35, 67, 2048,
]

// CAT_PROBS contains the probabilities for decoding extra bits in each
// token category (cat1 through cat6). Indexed by: category offset then bit.
// cat1: 1 prob, cat2: 2, cat3: 3, cat4: 4, cat5: 5, cat6: 11.
// Total = 1+2+3+4+5+11 = 26 probs.
// Offsets: cat1=0, cat2=1, cat3=3, cat4=6, cat5=10, cat6=15.
pri const CAT_PROBS : roarray[26] base.u8 = [
        // cat1 (1 extra bit)
        159,
        // cat2 (2 extra bits)
        165, 145,
        // cat3 (3 extra bits)
        173, 148, 140,
        // cat4 (4 extra bits)
        176, 155, 140, 135,
        // cat5 (5 extra bits)
        180, 157, 141, 134, 130,
        // cat6 (11 extra bits)
        254, 254, 243, 230, 196, 177, 153, 140, 133, 130, 129,
]

// CAT_PROBS_OFFSET maps token category (5..10, meaning cat1..cat6) to an
// offset into CAT_PROBS.
pri const CAT_PROBS_OFFSET : roarray[12] base.u8[..= 15] = [
        0, 0, 0, 0, 0, 0, 1, 3, 6, 10, 15, 15,
]

// KF_Y_MODE_PROBS are the probabilities for decoding the luma prediction
// mode in key frames. Tree: 0→B_PRED(4), 1→(0→(0→DC, 1→V), 1→(0→H, 1→TM)).
// Mode values: DC=0, V=1, H=2, TM=3, B_PRED=4.
pri const KF_Y_MODE_PROBS : roarray[4] base.u8 = [
        145, 156, 163, 128,
]

